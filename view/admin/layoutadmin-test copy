<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi tiết Duyệt Người Bán - Admin Sample</title>
    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body { display: flex; flex-direction: column; min-height: 100vh; background-color: #f1f5f9; font-family: 'Inter', sans-serif; }
        .admin-navbar { background-color: #1e293b; padding: 12px 24px; }
        .admin-logo { font-size: 22px; font-weight: 700; color: #fff; text-decoration: none; letter-spacing: 0.5px; }
        .admin-logo-sub { font-size: 13px; color: #94a3b8; margin-left: 10px; padding-left: 10px; border-left: 1px solid #475569; }
        .admin-navbar .nav-link { color: #cbd5e1; font-weight: 500; font-size: 14.5px; text-decoration: none; }
        .admin-navbar .nav-link:hover { color: #fff; }
        .admin-footer { background-color: #ffffff; border-top: 1px solid #e2e8f0; padding: 16px 0; color: #64748b; font-size: 13.5px; text-align: center; margin-top: auto; }
        main { flex: 1; padding: 24px; }
    </style>
</head>
<body>

    <!-- HEADER SIMULATION -->
    <header class="admin-navbar shadow-sm sticky-top">
        <div class="container-fluid px-0">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <div class="d-flex align-items-center me-4">
                    <a href="#" class="admin-logo">2Life <span style="color: #38bdf8;">Admin</span></a>
                    <span class="admin-logo-sub d-none d-md-block">Hệ thống Quản trị</span>
                </div>
                <div class="d-flex align-items-center gap-4">
                    <span class="text-white small"><i class="bi bi-person-circle me-1"></i> Huỳnh N. Nhật Nam (Super Admin)</span>
                </div>
            </div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <main>
        <div class="container-fluid" style="max-width: 900px; margin: 0 auto;">
            <div class="mb-4">
                <a href="approve_seller_sample.html" class="text-decoration-none small text-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách
                </a>
                <h2 class="h4 mt-2 fw-bold text-dark">Hồ Sơ Cửa Hàng Bản Mẫu: An Store Đồ Cũ Vintage</h2>
            </div>

            <!-- THÔNG TIN CHỦ TÀI KHOẢN -->
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-white fw-bold py-3 text-primary">
                    <i class="bi bi-info-circle me-1"></i> Thông tin Người đăng ký (Từ bảng users)
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <p class="mb-1 text-secondary small">Họ và tên chủ tài khoản</p>
                            <h6 class="fw-bold text-dark">Nguyễn Văn A</h6>
                        </div>
                        <div class="col-md-6 mb-3">
                            <p class="mb-1 text-secondary small">Email đăng ký</p>
                            <h6 class="text-dark">nguyenvana@gmail.com</h6>
                        </div>
                        <div class="col-md-6 mb-3">
                            <p class="mb-1 text-secondary small">Số điện thoại liên hệ</p>
                            <h6 class="text-dark">0901234567</h6>
                        </div>
                    </div>
                </div>
            </div>

            <!-- THÔNG TIN HỒ SƠ SHOP CÓ SẴN TRONG DB -->
            <div class="card border-0 shadow-sm rounded-3 mb-4">
                <div class="card-header bg-white fw-bold py-3 text-success">
                    <i class="bi bi-shop me-1"></i> Thông tin Cửa hàng đề xuất (Từ bảng seller_profiles mẫu)
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <p class="mb-1 text-secondary small">Tên Shop hiển thị</p>
                            <h6 class="fw-bold fs-5 text-primary">An Store Đồ Cũ Vintage</h6>
                        </div>
                        <div class="col-md-6 mb-3">
                            <p class="mb-1 text-secondary small">Mã số thuế (Tax Code)</p>
                            <h6 class="text-dark fw-bold">8741029384</h6>
                        </div>
                        <div class="col-12 mb-2">
                            <p class="mb-1 text-secondary small">Mô tả cửa hàng kinh doanh</p>
                            <div class="p-3 bg-light rounded text-dark" style="font-size: 14.5px;">
                                Chuyên cung cấp sỉ và lẻ các loại quần áo thun mỹ, áo khoác denim, jacket da bò chính hiệu Vintage phong cách thập niên 80s, 90s. Hàng tuyển chọn kỹ lưỡng, độ mới cao từ 90-95%.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- KHỐI BUTTON DUYỆT / TỪ CHỐI -->
            <div class="card border-0 shadow-sm rounded-3 bg-light border">
                <div class="card-body p-4 text-center">
                    <h5 class="fw-bold mb-4">Quyết định Phê duyệt của Admin</h5>
                    <div class="d-flex justify-content-center gap-3">
                        <button class="btn btn-outline-danger px-4 py-2 fw-bold" onclick="alert('Mẫu: Sẽ thực hiện xóa profile để người dùng đăng ký lại nếu từ chối.')">
                            <i class="bi bi-x-circle-fill me-1"></i> Từ chối hồ sơ
                        </button>
                        <button class="btn btn-success px-4 py-2 fw-bold" onclick="alert('Mẫu: Sẽ cập nhật is_verified = 1 để kích hoạt Shop.')">
                            <i class="bi bi-check-circle-fill me-1"></i> Chấp thuận mở Shop
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- FOOTER SIMULATION -->
    <footer class="admin-footer">
        <div class="container-fluid">
            © 2026 2Life Admin Panel - Hệ thống quản trị nội bộ.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>