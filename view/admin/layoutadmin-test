<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Duyệt Người Bán - Admin Sample</title>
    <!-- Bootstrap 5 & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body { display: flex; flex-direction: column; min-height: 100vh; background-color: #f1f5f9; font-family: 'Inter', sans-serif; }
        .admin-navbar { background-color: #1e293b; padding: 12px 24px; }
        .admin-logo { font-size: 22px; font-weight: 700; color: #fff; text-decoration: none; letter-spacing: 0.5px; }
        .admin-logo-sub { font-size: 13px; color: #94a3b8; margin-left: 10px; padding-left: 10px; border-left: 1px solid #475569; }
        .admin-navbar .nav-link { color: #cbd5e1; font-weight: 500; font-size: 14.5px; text-decoration: none; }
        .admin-navbar .nav-link:hover { color: #fff; }
        .dropdown-menu { border: none; border-radius: 8px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
        .admin-footer { background-color: #ffffff; border-top: 1px solid #e2e8f0; padding: 16px 0; color: #64748b; font-size: 13.5px; text-align: center; margin-top: auto; }
        main { flex: 1; padding: 24px; }
    </style>
</head>
<body>

    <!-- HEADER SIMULATION -->
    <header class="admin-navbar shadow-sm sticky-top">
        <div class="container-fluid px-0">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <div class="d-flex align-items-center me-4">
                    <a href="#" class="admin-logo">2Life <span style="color: #38bdf8;">Admin</span></a>
                    <span class="admin-logo-sub d-none d-md-block">Hệ thống Quản trị</span>
                </div>
                <ul class="nav me-auto mb-2 mb-md-0 gap-1 d-none d-lg-flex">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle active text-white" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-grid-fill me-1"></i> Quản lý
                        </a>
                        <ul class="dropdown-menu shadow show" style="position: absolute; display: none;">
                            <li><a class="dropdown-item py-2" href="#"><i class="bi bi-tags me-2 text-secondary"></i>Quản lý danh mục</a></li>
                            <li><a class="dropdown-item py-2 active" href="#"><i class="bi bi-people me-2"></i>Quản lý tài khoản</a></li>
                            <li><a class="dropdown-item py-2" href="#"><i class="bi bi-card-checklist me-2 text-secondary"></i>Phê duyệt tin đăng</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="#"><i class="bi bi-headset me-1"></i> Hỗ trợ (CSKH)</a></li>
                </ul>
                <div class="d-flex align-items-center gap-4">
                    <span class="text-white small d-none d-sm-inline"><i class="bi bi-person-circle me-1"></i> Huỳnh N. Nhật Nam (Super Admin)</span>
                </div>
            </div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <main>
        <div class="container-fluid">
            <div class="mb-4">
                <h2 class="h4 mb-1 fw-bold text-dark">Quản Lý Đăng Ký Bán Hàng (approveseller)</h2>
                <p class="text-secondary small">Duyệt yêu cầu mở Shop của các thành viên trên hệ thống từ dữ liệu seller_profiles hiện tại.</p>
            </div>

            <!-- TABS TRẠNG THÁI (MẪU) -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-3">
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary btn-sm px-4">
                            Đang chờ duyệt (Mẫu)
                        </button>
                        <button class="btn btn-light text-secondary btn-sm px-4">
                            Shop đã phê duyệt
                        </button>
                    </div>
                </div>
            </div>

            <!-- BẢNG DANH SÁCH MẪU GIAO DIỆN -->
            <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="font-size: 14.5px;">
                        <thead class="table-light text-secondary fw-semibold">
                            <tr>
                                <th class="ps-4">Chủ tài khoản</th>
                                <th>Tên Shop</th>
                                <th>Số điện thoại</th>
                                <th>Ngày nộp đơn</th>
                                <th class="pe-4 text-end">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">Nguyễn Văn A</div>
                                    <small class="text-muted">nguyenvana@gmail.com</small>
                                </td>
                                <td class="fw-medium text-primary">An Store Đồ Cũ V Vintage</td>
                                <td>0901234567</td>
                                <td class="text-secondary small">21/05/2026 14:32</td>
                                <td class="pe-4 text-end">
                                    <a href="approve_seller_detail_sample.html" class="btn btn-outline-secondary btn-sm px-3">
                                        <i class="bi bi-search me-1"></i>Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">Trần Thị B</div>
                                    <small class="text-muted">tranthib@gmail.com</small>
                                </td>
                                <td class="fw-medium text-primary">Bình Minh Books & Gadgets</td>
                                <td>0918765432</td>
                                <td class="text-secondary small">20/05/2026 09:15</td>
                                <td class="pe-4 text-end">
                                    <a href="#" class="btn btn-outline-secondary btn-sm px-3">
                                        <i class="bi bi-search me-1"></i>Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        </tbody>s
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- FOOTER SIMULATION -->
    <footer class="admin-footer">
        <div class="container-fluid">
            © 2026 2Life Admin Panel - Hệ thống quản trị nội bộ.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>